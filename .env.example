# Server-level configuration for the Trading Volatility MCP server.
# Copy to .env (git-ignored) and fill in. All values are optional — see docs/README.

# Your Trading Volatility API key. Used in local mode; in hosted mode the key arrives
# per request via the Authorization / X-Api-Key header instead.
TV_API_KEY=

# Override the v2 API base URL (rarely needed).
# TV_API_BASE_URL=https://stocks.tradingvolatility.net/api/v2

# Path to a local-mode JSON config file holding the key (see config.example.json).
# TV_CONFIG_FILE=config.json

# Transport for `python -m tv_mcp` / `tv-mcp`: "stdio" (default) or "http".
# TV_MCP_TRANSPORT=stdio

# HTTP transport bind address (containers set HOST=0.0.0.0; Cloud Run injects PORT).
# HOST=127.0.0.1
# PORT=8000

# --- Hosted hardening (HTTP transport) ---
# Comma-separated CORS allow-origins ("*" = any; safe since no cookies/credentials).
# CORS_ALLOW_ORIGINS=*
# Max inbound request body in bytes; larger requests get 413 (MCP JSON-RPC is tiny).
# TV_MAX_REQUEST_BYTES=262144
# Require an API key: reject anonymous demo-mode calls (set true on public deployments).
# TV_REQUIRE_KEY=false
# Upstream retry budget per call (lower in hosted mode, e.g. 1).
# TV_MAX_RETRIES=2
# Upstream per-request timeout (seconds).
# TV_REQUEST_TIMEOUT=30

# LOG_LEVEL=INFO
